page {
  height: 100%;
  background: linear-gradient(135deg, #134e4a 0%, #042f2e 100%);
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 120rpx 40rpx 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
}

.logo {
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.4);
  /* 微交互：赋予Logo生命力的呼吸悬浮动画 */
  animation: float 3.5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-12px); }
  100% { transform: translateY(0px); }
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
  color: #dcfce3;
}

.slogan {
  font-size: 28rpx;
  color: #86efac;
  opacity: 0.8;
  letter-spacing: 2rpx;
}

.login-box {
  width: 100%;
  margin-top: auto;
  margin-bottom: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-primary {
  width: 85% !important;
  background: #22c55e;
  border-radius: 50rpx;
  padding: 24rpx 0;
  box-shadow: 0 10rpx 25rpx rgba(34, 197, 94, 0.3);
  transition: all 0.2s ease;
}

/* 情感化设计：按压时的阻尼反馈 */
.btn-primary:active {
  transform: scale(0.96);
  background: #16a34a;
  box-shadow: 0 5rpx 10rpx rgba(34, 197, 94, 0.2);
}

.btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.invite-section {
  width: 85%;
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.divider {
  font-size: 24rpx;
  color: #4ade80;
  opacity: 0.5;
  margin-bottom: 40rpx;
}

.invite-input {
  width: 100%;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(134, 239, 172, 0.15);
  transition: border 0.3s;
}

.invite-input:focus {
  border: 1px solid rgba(134, 239, 172, 0.6);
}

.ph-color {
  color: rgba(255, 255, 255, 0.3);
}

.btn-secondary {
  width: 100% !important;
  background: transparent;
  border: 2rpx solid #4ade80;
  color: #4ade80;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  background: rgba(74, 222, 128, 0.15);
  transform: scale(0.96);
}

.footer {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}