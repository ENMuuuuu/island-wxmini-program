page {
  height: 100%;
  background: #060F1E;
  color: #fff;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

/* ---- Nav bar ---- */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 20rpx;
  flex-shrink: 0;
}

.nav-greeting {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 4rpx;
}

.nav-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  display: block;
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(245,200,66,0.12);
  border: 1rpx solid rgba(245,200,66,0.25);
  border-radius: 9999rpx;
  padding: 10rpx 24rpx;
}

.streak-fire {
  font-size: 28rpx;
}

.streak-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #F5C842;
}

/* ---- Canvas area ---- */
.canvas-wrap {
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}

.island-canvas {
  display: block;
}

.island-stats {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(6,15,30,0.7);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 9999rpx;
  padding: 8rpx 28rpx;
  backdrop-filter: blur(10px);
}

.island-stat-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 1rpx;
}

/* ---- Habit section ---- */
.habit-section {
  flex: 1;
  overflow: hidden;
  background: rgba(255,255,255,0.02);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  border-top: 1rpx solid rgba(255,255,255,0.07);
}

.habit-scroll {
  height: 100%;
  padding: 36rpx 40rpx 0;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.section-tag {
  background: rgba(61,216,196,0.12);
  border: 1rpx solid rgba(61,216,196,0.2);
  border-radius: 9999rpx;
  padding: 6rpx 20rpx;
}

.section-tag-text {
  font-size: 22rpx;
  color: #3DD8C4;
}

/* ---- Habit card ---- */
.habit-card-wrap {
  margin-bottom: 20rpx;
}

.habit-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 28rpx;
  padding: 28rpx 28rpx;
  transition: all 0.25s ease;
  gap: 20rpx;
}

.habit-card.done {
  background: rgba(76,217,123,0.05);
  border-color: rgba(76,217,123,0.12);
  opacity: 0.7;
}

.habit-card:active {
  transform: scale(0.98);
  background: rgba(255,255,255,0.08);
}

/* Theme color indicator dot */
.theme-dot {
  width: 10rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}
.theme-dot.island   { background: #3DD8C4; }
.theme-dot.building { background: #FF7B5C; }
.theme-dot.stars    { background: #F5C842; }

.habit-info {
  flex: 1;
  min-width: 0;
}

.habit-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.habit-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.habit-streak {
  font-size: 22rpx;
  color: #F5C842;
}

.habit-theme-label {
  font-size: 22rpx;
  opacity: 0.6;
}

/* ---- Charge button ---- */
.charge-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  transition: transform 0.15s ease;
}

.charge-btn:active,
.charge-btn.charging {
  transform: scale(0.93);
}

.charge-ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 3rpx solid rgba(255,255,255,0.12);
}

.charge-ring-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, #3DD8C4, #2AB8A6);
  transition: height 0.04s linear;
  border-radius: 0 0 44rpx 44rpx;
}

.charge-btn.charging .charge-ring-fill {
  box-shadow: 0 0 20rpx rgba(61,216,196,0.5);
}

.charge-hint {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  z-index: 2;
}

/* ---- Done badge ---- */
.done-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(76,217,123,0.15);
  border: 2rpx solid rgba(76,217,123,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.done-check {
  font-size: 34rpx;
  color: #4CD97B;
  font-weight: 700;
}

/* ---- Add habit button ---- */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100rpx;
  border: 2rpx dashed rgba(255,255,255,0.12);
  border-radius: 28rpx;
  margin-top: 8rpx;
  transition: all 0.2s ease;
}

.add-btn:active {
  background: rgba(255,255,255,0.04);
  border-color: rgba(61,216,196,0.3);
}

.add-icon {
  font-size: 32rpx;
  color: rgba(255,255,255,0.25);
}

.add-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.25);
}

/* ---- Decay chip on habit card ---- */
.habit-card.has-decay {
  border-color: rgba(255,123,92,0.15);
}

.decay-chip {
  display: flex;
  align-items: center;
  background: rgba(255,123,92,0.12);
  border: 1rpx solid rgba(255,123,92,0.22);
  border-radius: 9999rpx;
  padding: 3rpx 14rpx;
}

.decay-chip-text {
  font-size: 20rpx;
  color: #FF7B5C;
}

/* ---- Co-build partner status bar ---- */
.cobuild-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(245,200,66,0.06);
  border: 1rpx solid rgba(245,200,66,0.15);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.cobuild-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(245,200,66,0.12);
  border: 2rpx solid rgba(245,200,66,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cobuild-avatar-emoji { font-size: 32rpx; }

.cobuild-info {
  flex: 1;
  min-width: 0;
}

.cobuild-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}

.cobuild-status {
  display: block;
  font-size: 21rpx;
  color: rgba(255,255,255,0.35);
}

.cobuild-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
  flex-shrink: 0;
}

.cobuild-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.2);
  transition: all 0.3s ease;
}

.cobuild-dot.done {
  background: #F5C842;
  border-color: #F5C842;
  box-shadow: 0 0 8rpx rgba(245,200,66,0.5);
}

.cobuild-tag {
  background: rgba(245,200,66,0.15);
  border: 1rpx solid rgba(245,200,66,0.25);
  border-radius: 9999rpx;
  padding: 6rpx 16rpx;
  flex-shrink: 0;
}

.cobuild-tag-text {
  font-size: 20rpx;
  color: #F5C842;
  font-weight: 600;
}

/* ---- Partner badge on canvas ---- */
.partner-canvas-badge {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(6,15,30,0.75);
  border: 1rpx solid rgba(245,200,66,0.3);
  border-radius: 9999rpx;
  padding: 8rpx 20rpx;
  backdrop-filter: blur(8px);
}

.partner-badge-dot {
  font-size: 16rpx;
  color: #F5C842;
}

.partner-badge-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
}

/* ---- Empty state ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  gap: 12rpx;
}

.empty-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.55);
}

.empty-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
}

.celebrate-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 100;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.celebrate-overlay.show {
  opacity: 1;
}

.celebrate-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
}

.particle {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  margin: -6rpx;
  transform-origin: center center;
  animation: particleBurst 0.8s cubic-bezier(0.2, 0.8, 0.4, 1) forwards;
}

@keyframes particleBurst {
  0%   { transform: rotate(var(--angle, 0deg)) translateY(0) scale(1); opacity: 1; }
  80%  { opacity: 1; }
  100% { transform: rotate(var(--angle, 0deg)) translateY(-120rpx) scale(0); opacity: 0; }
}

.celebrate-text {
  position: absolute;
  font-size: 28rpx;
  font-weight: 700;
  color: #3DD8C4;
  text-align: center;
  background: rgba(6,15,30,0.85);
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(61,216,196,0.3);
  white-space: nowrap;
  animation: celebrateFloat 2.2s ease forwards;
}

@keyframes celebrateFloat {
  0%   { transform: translateY(20rpx); opacity: 0; }
  15%  { transform: translateY(0);      opacity: 1; }
  70%  { transform: translateY(-10rpx); opacity: 1; }
  100% { transform: translateY(-40rpx); opacity: 0; }
}

/* ---- Note sheet ---- */
.note-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 60;
  pointer-events: none;
  transition: background 0.3s ease;
}
.note-mask.show {
  background: rgba(0,0,0,0.6);
  pointer-events: auto;
}

.note-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #0D1B2E;
  border-top: 1rpx solid rgba(255,255,255,0.08);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 20rpx 48rpx 80rpx;
  z-index: 61;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
}
.note-sheet.show {
  transform: translateY(0);
}

.note-handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.12);
  margin: 0 auto 36rpx;
}

.note-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.note-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
  margin-bottom: 32rpx;
}

.note-input-wrap {
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 24rpx 28rpx 16rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
}

.note-ph { color: rgba(255,255,255,0.2); }

.note-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: rgba(255,255,255,0.2);
  margin-top: 8rpx;
}

.note-actions {
  display: flex;
  gap: 20rpx;
}

.note-skip-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.note-skip-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
}

.note-save-btn {
  flex: 2;
  height: 96rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3DD8C4, #2ABCA8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(61,216,196,0.3);
  transition: all 0.2s ease;
}

.note-save-btn:active { transform: scale(0.97); }

.note-save-btn.disabled {
  background: rgba(255,255,255,0.08);
  box-shadow: none;
}

.note-save-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #060F1E;
}

.note-save-btn.disabled .note-save-text {
  color: rgba(255,255,255,0.3);
}

/* ---- Birthday wish overlay ---- */
.bday-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  transition: background 0.4s ease;
}

.bday-overlay.show {
  background: rgba(0,0,0,0.7);
  pointer-events: auto;
}

.bday-card {
  width: 560rpx;
  background: #0D1B2E;
  border: 1rpx solid rgba(61,216,196,0.2);
  border-radius: 40rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 0 80rpx rgba(61,216,196,0.15), 0 40rpx 80rpx rgba(0,0,0,0.4);
  transform: scale(0.85);
  opacity: 0;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s ease;
}

.bday-overlay.show .bday-card {
  transform: scale(1);
  opacity: 1;
}

.bday-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.bday-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.bday-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  text-align: center;
}

.bday-wish {
  font-size: 26rpx;
  color: rgba(61,216,196,0.7);
  text-align: center;
  line-height: 1.6;
  margin-top: 8rpx;
}

.bday-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3DD8C4, #2ABCA8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(61,216,196,0.3);
}

.bday-btn:active { transform: scale(0.97); }

.bday-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #060F1E;
}
