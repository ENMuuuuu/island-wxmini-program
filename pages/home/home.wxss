/* pages/home/home.wxss */
page {
  height: 100%;
  background: linear-gradient(180deg, #042f2e 0%, #134e4a 100%);
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  overflow: hidden;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* ================= 岛屿展示区 (55%) ================= */
.island-area {
  height: 55%;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.isometric-canvas {
  width: 500rpx;
  height: 500rpx;
  position: relative;
  /* 如果有需求可以加 transform: rotateX(60deg) 等真3D属性，但纯2D切图更稳妥 */
}

.block {
  width: 120rpx;
  height: 140rpx; /* 根据实际切图比例调整 */
  position: absolute;
  transition: filter 1s ease; /* 黯淡的渐变过渡 */
}

.dimmed {
  filter: grayscale(80%) brightness(50%); /* 习惯中断的惩罚隐喻：失去生机 */
}

/* 方块掉落的 Q 弹物理动效 */
.falling-anim {
  animation: dropIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes dropIn {
  0% { transform: translateY(-300rpx) scale(1.1); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}


/* ================= 打卡操作区 (45%) ================= */
.habit-area {
  height: 45%;
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px); /* 核心：毛玻璃质感 */
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding: 40rpx 0;
  box-sizing: border-box;
}

.section-title {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.section-title text {
  font-size: 36rpx;
  font-weight: bold;
  color: #dcfce3;
}

.section-title .subtitle {
  font-size: 22rpx;
  color: #4ade80;
  opacity: 0.6;
  font-weight: normal;
}

.habit-card {
  margin: 0 40rpx 24rpx 40rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.card-completed {
  opacity: 0.5;
  background: rgba(0, 0, 0, 0.2);
}

.material-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
}

.material-icon image {
  width: 100%;
  height: 100%;
}

.habit-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.habit-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.habit-streak {
  font-size: 22rpx;
  color: #fb923c; /* 连击橘色 */
}

/* ======= 长按蓄力节点 ======= */
.action-node {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.2);
}

.node-outline {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border: 4rpx solid rgba(134, 239, 172, 0.4);
  border-radius: 16rpx;
  z-index: 2;
}

.node-fill {
  width: 100%;
  background: #22c55e;
  transition: height 0.05s linear;
  z-index: 1;
  opacity: 0.3; /* 默认透明度写在这里 */
}

/* 新增：开始蓄力时的透明度 */
.node-fill.is-charging {
  opacity: 1;
}

.action-done {
  width: 80rpx;
  height: 80rpx;
  background: rgba(34, 197, 94, 0.2);
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.done-icon {
  color: #22c55e;
  font-weight: bold;
  font-size: 36rpx;
}

.bottom-padding {
  height: 60rpx;
}