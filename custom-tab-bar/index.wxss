.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(6, 15, 30, 0.95);
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding-bottom: env(safe-area-inset-bottom);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 1000;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
  position: relative;
  transition: all 0.25s ease;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item.active .tab-icon {
  transform: scale(1.15) translateY(-2rpx);
}

.tab-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: color 0.25s ease;
}

.tab-item.active .tab-text {
  color: #3DD8C4;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 32rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #3DD8C4;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-indicator.show {
  transform: translateX(-50%) scaleX(1);
}
