<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view
    wx:for="{{tabs}}"
    wx:key="page"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="tab-icon">{{item.icon}}</text>
    <text class="tab-text">{{item.text}}</text>
    <view class="tab-indicator {{selected === index ? 'show' : ''}}"></view>
  </view>
</view>
